generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Chat sessions (both agents) ────────────────────────────────────
model Session {
  id        String    @id @default(cuid())
  title     String    @default("New Session")
  agentId   String    @default("securityAgent") // "securityAgent" | "bankingAgent"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([agentId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant"
  content   String
  parts     Json     // raw UIMessage parts array
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ── Fake banking data (Alex's world) ──────────────────────────────
model BankCustomer {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  phone        String
  verified     Boolean         @default(false)
  createdAt    DateTime        @default(now())
  accounts     BankAccount[]
}

model BankAccount {
  id           String            @id @default(cuid())
  customerId   String
  accountNo    String            @unique
  type         String            // "checking" | "savings" | "credit"
  balance      Float
  currency     String            @default("USD")
  status       String            @default("active") // "active" | "frozen" | "closed"
  createdAt    DateTime          @default(now())
  customer     BankCustomer      @relation(fields: [customerId], references: [id])
  transactions BankTransaction[]

  @@index([customerId])
}

model BankTransaction {
  id          String      @id @default(cuid())
  accountId   String
  type        String      // "debit" | "credit" | "transfer"
  amount      Float
  description String
  merchant    String?
  status      String      @default("completed")
  createdAt   DateTime    @default(now())
  account     BankAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

// ── Attack audit log ───────────────────────────────────────────────
model AttackLog {
  id             String   @id @default(cuid())
  sessionId      String?
  agentId        String   // which agent was attacked
  attackType     String?  // "LLM01" | "LLM02" etc
  userMessage    String
  agentResponse  String?
  provider       String
  model          String
  vulnerable     Boolean? // null = unknown, true = bypassed, false = defended
  createdAt      DateTime @default(now())

  @@index([agentId])
  @@index([attackType])
}



// ══════════════════════════════════════════════════════════════════
// PLATFORM — Security Testing Engine
// ══════════════════════════════════════════════════════════════════

model Target {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // "external_url"|"openai"|"anthropic"|"ollama"|"groq"|"openrouter"|"template"
  endpoint    String?  // for external_url type
  provider    String?  // for direct LLM types
  model       String?  // e.g. "qwen3:8b"
  apiKey      String?  // stored as plain text for now
  headers     Json?    // extra HTTP headers as key/value object
  templateId  String?  // "banking" | "securebot" for built-in templates
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflows  Workflow[]
  attackRuns AttackRun[]

  @@index([type])
}

model Workflow {
  id               String   @id @default(cuid())
  name             String
  description      String?
  targetId         String
  mode             String   @default("manual") // "manual" | "auto"
  attackCategories Json?    // string[] e.g. ["LLM01","LLM02","LLM07"]
  status           String   @default("idle")   // "idle"|"running"|"done"|"failed"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  target Target        @relation(fields: [targetId], references: [id], onDelete: Cascade)
  runs   WorkflowRun[]

  @@index([targetId])
}

model WorkflowRun {
  id            String    @id @default(cuid())
  workflowId    String
  status        String    @default("running") // "running"|"done"|"failed"
  securityScore Int?      // 0-100, null until analysis finishes
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?

  workflow    Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  attackRuns  AttackRun[]
  findings    Finding[]
  threatModel ThreatModel?

  @@index([workflowId])
}

model AttackRun {
  id            String   @id @default(cuid())
  workflowRunId String
  targetId      String
  owaspCategory String   // "LLM01" | "LLM02" etc.
  attackName    String   // e.g. "Direct Prompt Injection"
  payload       String   // the exact prompt sent to the target
  response      String?  // what the target replied
  success       Boolean? // null=not analyzed yet, true=vulnerable, false=defended
  createdAt     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  target      Target      @relation(fields: [targetId], references: [id])
  finding     Finding?

  @@index([workflowRunId])
  @@index([owaspCategory])
}

model Finding {
  id             String   @id @default(cuid())
  workflowRunId  String
  attackRunId    String?  @unique  // one finding per attack run
  title          String
  owaspCategory  String
  severity       String   // "critical"|"high"|"medium"|"low"|"info"
  confidence     Int      // 0-100
  description    String
  evidence       String?  // quote from the target response that proves it
  recommendation String
  createdAt      DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  attackRun   AttackRun?  @relation(fields: [attackRunId], references: [id])

  @@index([workflowRunId])
  @@index([severity])
}

model ThreatModel {
  id            String   @id @default(cuid())
  workflowRunId String   @unique  // one threat model per run
  targetName    String?
  domain        String?  // e.g. "Banking", "Customer Support"
  tools         Json?    // string[] of discovered tools
  risks         Json?    // string[] of recommended attack categories
  rawOutput     Json?    // full JSON from the recon agent
  createdAt     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
}